{
  "name": "@techode/booking",
  "version": "0.2.2",
  "description": "Embeddable booking widget for React/Next.js projects. Powered by Google Calendar.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.mjs",
      "require": "./dist/api.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "googleapis": "^144"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "react": "^18",
    "react-dom": "^18",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/techode-spa/techode-booking"
  }
}
